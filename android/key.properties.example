# Release 서명 설정 (복사 후 key.properties로 저장하고 실제 값 입력)
# cp key.properties.example key.properties
# ⚠️ key.properties는 .gitignore에 등록되어 있습니다. Git/웹/클라우드에 업로드 금지.

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=upload
# 프로젝트 루트 기준 고정 경로 (android/ 내부)
storeFile=upload-keystore.jks
